{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codec-through.local/schemas/sam_scaleout_artifact_v1.schema.json",
  "title": "Sam scale-out artifact row v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "run_id",
    "phase",
    "model_id",
    "runtime",
    "hardware",
    "policy",
    "video_id",
    "item_id",
    "turn_index",
    "prompt_frame_count",
    "baseline_choice",
    "session_choice",
    "baseline_correct",
    "session_correct",
    "parse_failure",
    "elapsed_ms",
    "raw_response"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "phase": { "type": "string" },
    "model_id": { "type": "string" },
    "runtime": { "type": "string" },
    "hardware": { "type": "string" },
    "policy": { "type": "string" },
    "video_id": { "type": "string" },
    "item_id": { "type": "string" },
    "turn_index": { "type": "integer", "minimum": 0 },
    "prompt_frame_count": { "type": "integer", "minimum": 0 },
    "baseline_choice": { "type": ["string", "null"] },
    "session_choice": { "type": ["string", "null"] },
    "baseline_correct": { "type": "boolean" },
    "session_correct": { "type": "boolean" },
    "parse_failure": { "type": "boolean" },
    "elapsed_ms": { "type": "number", "minimum": 0 },
    "baseline_elapsed_ms": { "type": ["number", "null"], "minimum": 0 },
    "prefix_hit": { "type": ["integer", "null"], "minimum": 0 },
    "input_len": { "type": ["integer", "null"], "minimum": 0 },
    "prefix_coverage": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "peak_memory_gb": { "type": ["number", "null"], "minimum": 0 },
    "raw_response": { "type": "string" },
    "baseline_raw_response": { "type": ["string", "null"] },
    "seed": { "type": ["integer", "null"] },
    "temperature": { "type": ["number", "null"] },
    "top_p": { "type": ["number", "null"] },
    "commit_sha": { "type": ["string", "null"] }
  }
}
